{
  "name": "diegosaid",
  "description": "Diego Said — personal portfolio (React + Vite + Tailwind, deployed on Cloudflare Pages).",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://diegosaid.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/redcpp/diegosaid.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=diegosaid",
    "deploy:prod": "git push origin main && npm run deploy"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "katex": "^0.17.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.15.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
